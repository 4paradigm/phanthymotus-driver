# DJI E-Port USB serial device — auto-permission for container access
# Install on host: cp 99-eport.rules /etc/udev/rules.d/ && udevadm control --reload-rules

# DJI USB devices (VID 0x2CA3)
SUBSYSTEM=="tty", ATTRS{idVendor}=="2ca3", MODE="0666", SYMLINK+="dji_eport"

# USB ACM device (fallback for ttyACM*)
KERNEL=="ttyACM[0-9]*", ATTRS{idVendor}=="2ca3", MODE="0666", SYMLINK+="dji_eport"

# USB RNDIS/NCM network interface from E-Port (auto-up)
SUBSYSTEM=="net", ATTRS{idVendor}=="2ca3", ACTION=="add", RUN+="/sbin/ip link set %k up"
