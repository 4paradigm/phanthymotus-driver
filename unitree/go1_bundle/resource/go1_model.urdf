<?xml version="1.0"?>
<!--
  go1_model.urdf — Unitree Go1 四足骨骼模型（供 dashboard skeleton renderer 用）。
  用 box/cylinder/sphere 搭建，无 mesh 依赖，自包含。关节树结构/命名/旋转轴/连杆尺寸
  按宇树 go1_description 标准（尺寸取自公开 const）。
  关节命名沿用官方约定 <腿>_hip/thigh/calf_joint（腿序 FR/FL/RR/RL）——需与 joints 卡
  上报的关节名一致，渲染器才能按 q_rad 正确摆动。
  轴：hip 绕 X(外摆)，thigh/calf 绕 Y(俯仰)。连杆：thigh=calf=0.213m。
-->
<robot name="go1_description">

  <material name="trunk_color"><color rgba="0.2 0.2 0.2 1"/></material>
  <material name="leg"><color rgba="0.1 0.1 0.1 1"/></material>
  <material name="foot"><color rgba="0.9 0.2 0.2 1"/></material>

  <link name="trunk">
    <inertial><origin xyz="0 0 0"/><mass value="4.713"/><inertia ixx="0.0168" ixy="0" ixz="0" iyy="0.0565" iyz="0" izz="0.0647"/></inertial>
    <visual><origin xyz="0 0 0"/><geometry><box size="0.3762 0.0935 0.114"/></geometry><material name="trunk_color"/></visual>
    <collision><geometry><box size="0.3762 0.0935 0.114"/></geometry></collision>
  </link>

  <!-- ══ FR 右前 ══ -->
  <joint name="FR_hip_joint" type="revolute"><origin xyz="0.1881 -0.04675 0"/><parent link="trunk"/><child link="FR_hip"/><axis xyz="1 0 0"/><limit effort="23.7" velocity="30.1" lower="-1.047" upper="1.047"/></joint>
  <link name="FR_hip"><inertial><mass value="0.696"/><inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0009" iyz="0" izz="0.0006"/></inertial><visual><origin xyz="0 -0.04 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.046" length="0.08"/></geometry><material name="leg"/></visual></link>
  <joint name="FR_thigh_joint" type="revolute"><origin xyz="0 -0.08 0"/><parent link="FR_hip"/><child link="FR_thigh"/><axis xyz="0 1 0"/><limit effort="23.7" velocity="30.1" lower="-0.663" upper="2.966"/></joint>
  <link name="FR_thigh"><inertial><origin xyz="0 0 -0.1065"/><mass value="1.013"/><inertia ixx="0.0055" ixy="0" ixz="0" iyy="0.0053" iyz="0" izz="0.0009"/></inertial><visual><origin xyz="0 0 -0.1065"/><geometry><box size="0.035 0.03 0.213"/></geometry><material name="leg"/></visual></link>
  <joint name="FR_calf_joint" type="revolute"><origin xyz="0 0 -0.213"/><parent link="FR_thigh"/><child link="FR_calf"/><axis xyz="0 1 0"/><limit effort="35.5" velocity="20.1" lower="-2.721" upper="-0.837"/></joint>
  <link name="FR_calf"><inertial><origin xyz="0 0 -0.1065"/><mass value="0.166"/><inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.00003"/></inertial><visual><origin xyz="0 0 -0.1065"/><geometry><box size="0.02 0.016 0.213"/></geometry><material name="leg"/></visual></link>
  <joint name="FR_foot_joint" type="fixed"><origin xyz="0 0 -0.213"/><parent link="FR_calf"/><child link="FR_foot"/></joint>
  <link name="FR_foot"><inertial><mass value="0.06"/><inertia ixx="9.6e-06" ixy="0" ixz="0" iyy="9.6e-06" iyz="0" izz="9.6e-06"/></inertial><visual><geometry><sphere radius="0.02"/></geometry><material name="foot"/></visual></link>

  <!-- ══ FL 左前 ══ -->
  <joint name="FL_hip_joint" type="revolute"><origin xyz="0.1881 0.04675 0"/><parent link="trunk"/><child link="FL_hip"/><axis xyz="1 0 0"/><limit effort="23.7" velocity="30.1" lower="-1.047" upper="1.047"/></joint>
  <link name="FL_hip"><inertial><mass value="0.696"/><inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0009" iyz="0" izz="0.0006"/></inertial><visual><origin xyz="0 0.04 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.046" length="0.08"/></geometry><material name="leg"/></visual></link>
  <joint name="FL_thigh_joint" type="revolute"><origin xyz="0 0.08 0"/><parent link="FL_hip"/><child link="FL_thigh"/><axis xyz="0 1 0"/><limit effort="23.7" velocity="30.1" lower="-0.663" upper="2.966"/></joint>
  <link name="FL_thigh"><inertial><origin xyz="0 0 -0.1065"/><mass value="1.013"/><inertia ixx="0.0055" ixy="0" ixz="0" iyy="0.0053" iyz="0" izz="0.0009"/></inertial><visual><origin xyz="0 0 -0.1065"/><geometry><box size="0.035 0.03 0.213"/></geometry><material name="leg"/></visual></link>
  <joint name="FL_calf_joint" type="revolute"><origin xyz="0 0 -0.213"/><parent link="FL_thigh"/><child link="FL_calf"/><axis xyz="0 1 0"/><limit effort="35.5" velocity="20.1" lower="-2.721" upper="-0.837"/></joint>
  <link name="FL_calf"><inertial><origin xyz="0 0 -0.1065"/><mass value="0.166"/><inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.00003"/></inertial><visual><origin xyz="0 0 -0.1065"/><geometry><box size="0.02 0.016 0.213"/></geometry><material name="leg"/></visual></link>
  <joint name="FL_foot_joint" type="fixed"><origin xyz="0 0 -0.213"/><parent link="FL_calf"/><child link="FL_foot"/></joint>
  <link name="FL_foot"><inertial><mass value="0.06"/><inertia ixx="9.6e-06" ixy="0" ixz="0" iyy="9.6e-06" iyz="0" izz="9.6e-06"/></inertial><visual><geometry><sphere radius="0.02"/></geometry><material name="foot"/></visual></link>

  <!-- ══ RR 右后 ══ -->
  <joint name="RR_hip_joint" type="revolute"><origin xyz="-0.1881 -0.04675 0"/><parent link="trunk"/><child link="RR_hip"/><axis xyz="1 0 0"/><limit effort="23.7" velocity="30.1" lower="-1.047" upper="1.047"/></joint>
  <link name="RR_hip"><inertial><mass value="0.696"/><inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0009" iyz="0" izz="0.0006"/></inertial><visual><origin xyz="0 -0.04 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.046" length="0.08"/></geometry><material name="leg"/></visual></link>
  <joint name="RR_thigh_joint" type="revolute"><origin xyz="0 -0.08 0"/><parent link="RR_hip"/><child link="RR_thigh"/><axis xyz="0 1 0"/><limit effort="23.7" velocity="30.1" lower="-0.663" upper="2.966"/></joint>
  <link name="RR_thigh"><inertial><origin xyz="0 0 -0.1065"/><mass value="1.013"/><inertia ixx="0.0055" ixy="0" ixz="0" iyy="0.0053" iyz="0" izz="0.0009"/></inertial><visual><origin xyz="0 0 -0.1065"/><geometry><box size="0.035 0.03 0.213"/></geometry><material name="leg"/></visual></link>
  <joint name="RR_calf_joint" type="revolute"><origin xyz="0 0 -0.213"/><parent link="RR_thigh"/><child link="RR_calf"/><axis xyz="0 1 0"/><limit effort="35.5" velocity="20.1" lower="-2.721" upper="-0.837"/></joint>
  <link name="RR_calf"><inertial><origin xyz="0 0 -0.1065"/><mass value="0.166"/><inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.00003"/></inertial><visual><origin xyz="0 0 -0.1065"/><geometry><box size="0.02 0.016 0.213"/></geometry><material name="leg"/></visual></link>
  <joint name="RR_foot_joint" type="fixed"><origin xyz="0 0 -0.213"/><parent link="RR_calf"/><child link="RR_foot"/></joint>
  <link name="RR_foot"><inertial><mass value="0.06"/><inertia ixx="9.6e-06" ixy="0" ixz="0" iyy="9.6e-06" iyz="0" izz="9.6e-06"/></inertial><visual><geometry><sphere radius="0.02"/></geometry><material name="foot"/></visual></link>

  <!-- ══ RL 左后 ══ -->
  <joint name="RL_hip_joint" type="revolute"><origin xyz="-0.1881 0.04675 0"/><parent link="trunk"/><child link="RL_hip"/><axis xyz="1 0 0"/><limit effort="23.7" velocity="30.1" lower="-1.047" upper="1.047"/></joint>
  <link name="RL_hip"><inertial><mass value="0.696"/><inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0009" iyz="0" izz="0.0006"/></inertial><visual><origin xyz="0 0.04 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.046" length="0.08"/></geometry><material name="leg"/></visual></link>
  <joint name="RL_thigh_joint" type="revolute"><origin xyz="0 0.08 0"/><parent link="RL_hip"/><child link="RL_thigh"/><axis xyz="0 1 0"/><limit effort="23.7" velocity="30.1" lower="-0.663" upper="2.966"/></joint>
  <link name="RL_thigh"><inertial><origin xyz="0 0 -0.1065"/><mass value="1.013"/><inertia ixx="0.0055" ixy="0" ixz="0" iyy="0.0053" iyz="0" izz="0.0009"/></inertial><visual><origin xyz="0 0 -0.1065"/><geometry><box size="0.035 0.03 0.213"/></geometry><material name="leg"/></visual></link>
  <joint name="RL_calf_joint" type="revolute"><origin xyz="0 0 -0.213"/><parent link="RL_thigh"/><child link="RL_calf"/><axis xyz="0 1 0"/><limit effort="35.5" velocity="20.1" lower="-2.721" upper="-0.837"/></joint>
  <link name="RL_calf"><inertial><origin xyz="0 0 -0.1065"/><mass value="0.166"/><inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.00003"/></inertial><visual><origin xyz="0 0 -0.1065"/><geometry><box size="0.02 0.016 0.213"/></geometry><material name="leg"/></visual></link>
  <joint name="RL_foot_joint" type="fixed"><origin xyz="0 0 -0.213"/><parent link="RL_calf"/><child link="RL_foot"/></joint>
  <link name="RL_foot"><inertial><mass value="0.06"/><inertia ixx="9.6e-06" ixy="0" ixz="0" iyy="9.6e-06" iyz="0" izz="9.6e-06"/></inertial><visual><geometry><sphere radius="0.02"/></geometry><material name="foot"/></visual></link>

</robot>
