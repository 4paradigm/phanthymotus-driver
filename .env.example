# PhanthyMotus Driver Build Configuration
# Copy this file to .env and fill in values (optional — without it, builds stay local)
#
# cp .env.example .env

# ── Registry (optional) ────────────────────────────────────────────────────
# If not set, build.sh will build images locally without pushing.

# Image registry address (e.g., Tencent Cloud TCR, Docker Hub, GitHub CR)
# REGISTRY=ccr.ccs.tencentyun.com

# Registry credentials
# REGISTRY_USER=your-username
# REGISTRY_PASSWORD=your-password

# Image namespace prefix
# Final image format: ${REGISTRY}/${IMAGE_NAMESPACE}/${provider}/${model}:${TAG}
# IMAGE_NAMESPACE=phanthy-motus/drivers

# ── Resource Center (optional) ─────────────────────────────────────────────
# After build, optionally register images to Resource Center for review & publish.
# If not set, the registration step is skipped.

# RESOURCE_CENTER_URL=https://motus.phanthy.com
# RESOURCE_CENTER_API_KEY=rc_your_api_key_here
