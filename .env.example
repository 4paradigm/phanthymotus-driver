# 硬件驱动构建配置
# 此文件由 build.sh 从 ../phanthy-motus/deploy/.env 读取
# 复制方式：cp .env.example ../phanthy-motus/deploy/.env，填入真实值

# 镜像仓库地址（腾讯云 TCR 示例）
REGISTRY=bj-warehouse.tencentcloudcr.com

# 仓库用户名
REGISTRY_USER=your-username

# 仓库密码或访问 Token
REGISTRY_PASSWORD=your-password

# 镜像命名空间前缀，例如：phanthy-motus/drivers
# 最终镜像格式：${REGISTRY}/${IMAGE_NAMESPACE}/${image_name}:${TAG}
IMAGE_NAMESPACE=phanthy-motus/drivers

# Resource Center 注册（可选）
# 构建完成后自动向 Resource Center 注册镜像，等待管理员审核发布
RESOURCE_CENTER_URL=https://resource.yourdomain.com
RESOURCE_CENTER_API_KEY=rc_your_api_key_here
